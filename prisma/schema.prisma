// schema.prisma — Tempest Finance PWA
// Prinsip: Clean Code, DRY, KISS, SoC
// Komunikasi DB hanya via: prisma migrate dev & prisma generate

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ============================================================
// MODEL USER — Autentikasi Pengguna (PIN 6 Digit)
// ============================================================
model User {
  id         String   @id @default(cuid())
  name       String
  pin        String   @unique
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())

  // ─── Relasi balik: data milik user ini ───────────────────
  accounts     Account[]
  categories   Category[]
  transactions Transaction[]
  budgets      Budget[]
  debts        Debt[]
}

// ============================================================
// MODEL ACCOUNT — Mewakili setiap akun keuangan pengguna
// ============================================================
model Account {
  id        String   @id @default(cuid())
  name      String
  balance   Float    @default(0)
  uangGoib  Float    @default(0)
  icon      String?
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions Transaction[] @relation("AccountTransactions")
  transfersIn  Transaction[] @relation("TransferTo")
}

// ============================================================
// MODEL CATEGORY — Klasifikasi transaksi (mendukung Parent/Child)
// Contoh: Makan (Parent) → Kopi, Snack (Children)
// ============================================================
model Category {
  id    String  @id @default(cuid())
  name  String
  type  String // "INCOME" atau "EXPENSE"
  icon  String?
  order Int     @default(0) // Urutan tampil di UI

  // ─── Self-relation: Parent → Children ────────────────────
  // parentId null = kategori root/parent
  parentId String?
  parent   Category?  @relation("SubCategories", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("SubCategories")

  // ─── Relasi ke User ──────────────────────────────────────
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions Transaction[]
  budgets      Budget[]
}

// ============================================================
// MODEL TRANSACTION — Data inti setiap transaksi keuangan
// ============================================================
model Transaction {
  id          String   @id @default(cuid())
  amount      Float
  type        String // "INCOME" | "EXPENSE" | "TRANSFER"
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  isSynced    Boolean  @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  accountId String
  account   Account @relation("AccountTransactions", fields: [accountId], references: [id])

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  toAccountId String?
  toAccount   Account? @relation("TransferTo", fields: [toAccountId], references: [id])

  adminFee Float? @default(0)
}

// ============================================================
// MODEL BUDGET — Batas pengeluaran per kategori per periode
// Contoh: Makan max Rp 2.000.000 / bulan
// ============================================================
model Budget {
  id     String @id @default(cuid())
  amount Float // Batas maksimal
  period String @default("MONTHLY") // "MONTHLY" | "WEEKLY"

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Satu budget per user per kategori per periode
  @@unique([userId, categoryId, period])
}

// ============================================================
// MODEL DEBT — Pencatat Hutang & Piutang
// HUTANG = kita yang berhutang ke orang lain
// PIUTANG = orang lain yang berhutang ke kita
// ============================================================
model Debt {
  id          String    @id @default(cuid())
  type        String // "HUTANG" | "PIUTANG"
  personName  String // Nama orang yang terlibat
  amount      Float // Nominal
  description String? // Catatan opsional
  dueDate     DateTime? // Jatuh tempo opsional
  isPaid      Boolean   @default(false)
  paidAt      DateTime? // Kapan dilunasi

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
