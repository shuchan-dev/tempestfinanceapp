// schema.prisma — Tempest Finance PWA
// Prinsip: Clean Code, DRY, KISS, SoC
// Komunikasi DB hanya via: prisma migrate dev & prisma generate

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// MODEL USER — Autentikasi Pengguna (PIN 6 Digit)
// ============================================================
model User {
  id         String   @id @default(cuid())
  name       String // Nama pengguna
  pin        String   @unique // PIN 6 digit untuk login
  isApproved Boolean  @default(false) // Default false, harus diubah manual ke true untuk bisa masuk
  createdAt  DateTime @default(now())

  // ─── Relasi balik: data milik user ini ───────────────────
  accounts     Account[]
  categories   Category[]
  transactions Transaction[]
}

// ============================================================
// MODEL ACCOUNT — Mewakili setiap akun keuangan pengguna
// Contoh: BCA, Gopay, Dompet Tunai
// ============================================================
model Account {
  id        String   @id @default(cuid())
  name      String // Nama akun, contoh: "BCA", "Gopay"
  balance   Float    @default(0) // Saldo saat ini
  uangGoib  Float    @default(0) // Uang minus/bon/utang tak terlihat
  icon      String? // Emoji icon opsional
  color     String? // Warna hex untuk badge warna di UI
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ─── Relasi ke User (isolasi data per pengguna) ──────────
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Transaksi reguler (INCOME/EXPENSE) dan transaksi asal TRANSFER
  transactions Transaction[] @relation("AccountTransactions")

  // Transaksi TRANSFER yang masuk ke akun ini (akun tujuan)
  transfersIn Transaction[] @relation("TransferTo")
}

// ============================================================
// MODEL CATEGORY — Klasifikasi transaksi
// Contoh: Makanan (EXPENSE), Gaji (INCOME)
// ============================================================
model Category {
  id   String  @id @default(cuid())
  name String // Nama kategori, contoh: "Makanan"
  type String // "INCOME" atau "EXPENSE"
  icon String? // Emoji icon opsional untuk UI

  // ─── Relasi ke User (isolasi data per pengguna) ──────────
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Semua transaksi yang masuk ke kategori ini
  transactions Transaction[]
}

// ============================================================
// MODEL TRANSACTION — Data inti setiap transaksi keuangan
// Mendukung tipe: INCOME, EXPENSE, TRANSFER
// ============================================================
model Transaction {
  id          String   @id @default(cuid())
  amount      Float // Nominal transaksi (selalu positif)
  type        String // "INCOME" | "EXPENSE" | "TRANSFER"
  description String? // Catatan opsional dari pengguna
  date        DateTime @default(now()) // Tanggal transaksi
  createdAt   DateTime @default(now())

  // Menandai apakah data sudah terupload ke Google Sheets
  // false = pending sync, true = sudah sinkron
  isSynced Boolean @default(false)

  // ─── Relasi ke User (isolasi data per pengguna) ──────────
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ─── Akun Asal (wajib untuk semua tipe transaksi) ────────
  accountId String
  account   Account @relation("AccountTransactions", fields: [accountId], references: [id])

  // ─── Kategori (opsional — TRANSFER tidak perlu kategori) ──
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  // ─── Field khusus TRANSFER ────────────────────────────────
  // toAccountId: ID akun tujuan (diisi hanya saat type = "TRANSFER")
  toAccountId String?
  toAccount   Account? @relation("TransferTo", fields: [toAccountId], references: [id])

  // adminFee: biaya transfer yang dibebankan ke akun asal
  adminFee Float? @default(0)
}
